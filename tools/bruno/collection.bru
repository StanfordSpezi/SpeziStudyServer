auth {
  mode: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  baseUrl: http://localhost:8080
  keycloakUrl: http://localhost:8180
  keycloakRealm: spezi-study
  keycloakClientId: spezi-study-server
  keycloakClientSecret: change-me-in-production
  keycloakUsername: leland
  keycloakPassword: password123
}
